# Database
# PostgreSQL connection string (required)
# For local PostgreSQL: postgresql://postgres:password@localhost:5432/hr_recruitment
# For Neon (free cloud): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/hr_recruitment?sslmode=require
# For Supabase (free cloud): postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/hr_recruitment"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Demo Mode
# Set to "true" to enable demo login with any email + password "password123"
# This is useful for development and testing when the database is not available
ENABLE_DEMO_LOGIN="true"

# Optional: Upload directory (defaults to public/uploads)
# UPLOAD_DIR="public/uploads"